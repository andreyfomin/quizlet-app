# Hugging Face Inference Providers router (https://router.huggingface.co/v1)
# Create a token at https://huggingface.co/settings/tokens (Read access is enough).
HF_API_TOKEN=

# Optional overrides — defaults are set in backend/src/main/resources/application.yml
# HF model used to generate quiz questions (chat-completions compatible).
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Postgres connection used by docker-compose.yml
DB_NAME=quizlet
DB_USERNAME=quizlet
DB_PASSWORD=quizlet

# Slack app credentials. Full setup guide: slackbot/README.md ("Create the Slack app").
# Quick version: create an app at https://api.slack.com/apps ("From an app manifest",
# manifest is in slackbot/README.md), install it to your workspace, then:
#   SLACK_BOT_TOKEN      — OAuth & Permissions -> Install to Workspace -> Bot User OAuth Token (xoxb-...)
#   SLACK_SIGNING_SECRET — Basic Information -> App Credentials -> Signing Secret
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Optional: lets `./gradlew slackManifestSync` keep the Slack app's Request URLs pointed
# at your current ngrok tunnel automatically, instead of re-pasting the URL by hand every
# time ngrok restarts (free ngrok assigns a new random URL each time). Setup (one-time,
# on the same https://api.slack.com/apps page as above):
#   SLACK_APP_ID              — Basic Information -> App ID
#   SLACK_CONFIG_REFRESH_TOKEN — "Your App Configuration Tokens" section (below your app
#                                list, not on the app's own pages) -> Generate Token ->
#                                copy the Refresh Token (starts xoxe-, not the xoxe.xoxp-
#                                access token — that one's fetched fresh automatically).
# This value is REWRITTEN automatically by slackManifestSync after every successful run
# (Slack rotates it each time) — leave it as whatever the script last wrote here.
SLACK_APP_ID=
SLACK_CONFIG_REFRESH_TOKEN=
